CB_EMAIL=your-email@example.com
CB_PASSWORD=your-password

# Path to a Chromium-based browser (Edge, Chrome, Brave, etc.)
# Windows examples:
#   C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe
#   C:\Program Files\Google\Chrome\Application\chrome.exe
# macOS examples:
#   /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
#   /Applications/Microsoft Edge.app/Contents/MacOS/Microsoft Edge
# Linux examples:
#   /usr/bin/google-chrome
#   /usr/bin/chromium-browser
BROWSER_PATH=

# Path to img2pdf (pip install img2pdf)
# Leave empty to auto-detect from PATH
IMG2PDF_PATH=

# Output directory for downloaded PDFs
OUTPUT_DIR=./output

# Render width in pixels (higher = better quality, larger files)
PAGE_WIDTH=1200
